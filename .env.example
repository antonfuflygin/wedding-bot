BOT_TOKEN=your_telegram_bot_token_here

# PostgreSQL connection. Use DATABASE_URL or the PG* variables below.
# Local run:
DATABASE_URL=postgres://postgres:password@localhost:5432/wedding_bot
# Docker Compose overrides DATABASE_URL automatically (host: db).
# PGHOST=localhost
# PGPORT=5432
# PGDATABASE=wedding_bot
# PGUSER=postgres
# PGPASSWORD=password
# PGSSL=false

# Cron expression. Default example: every day at 10:00.
DAILY_MESSAGE_CRON=0 10 * * *
CRON_TIMEZONE=Europe/Moscow
DAILY_MESSAGE_TEXT=Доброе утро! Напоминаем, что вся важная информация о свадьбе доступна в меню бота.

# Wedding config (seeded into wedding_config on first startup if the table is empty)
WEDDING_BRIDE_NAME=Имя1
WEDDING_GROOM_NAME=Имя2
WEDDING_DATE=25.06.26
WEDDING_CITY=Город
