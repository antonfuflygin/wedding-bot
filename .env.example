BOT_TOKEN=your_telegram_bot_token_here

# PostgreSQL credentials (used by Docker Compose and the bot).
POSTGRES_USER=your_postgres_user
POSTGRES_PASSWORD=your_postgres_password
POSTGRES_DB=wedding_bot_db
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
# PGSSL=false

# Optional timezone for formatting event start times.
# TIMEZONE=Europe/Moscow

# Wedding config (seeded into wedding_config on first startup if the table is empty)
WEDDING_BRIDE_NAME=Имя1
WEDDING_GROOM_NAME=Имя2
WEDDING_DATE=25.06.26
WEDDING_CITY=Город
